              "ioValues": [
                {
                  "name": "toMove",
                  "ioValue": "__GEOMETRY_INPUT__"
                },
                {
                  "name": "offsets",
                  "ioValue": [
                    "0.0",
                    "-2.5",
                    "-5.9",
                    "-9.0",
                    "-10.3",
