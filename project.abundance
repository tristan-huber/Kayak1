        },
        {
          "atomType": "Code",
          "x": 0.46289062500000006,
          "y": 0.3485714285714286,
          "uniqueID": "id-25851",
          "ioValues": [
            {
              "name": "surface",
              "ioValue": "__GEOMETRY_INPUT__"
            },
            {
              "name": "numRulings",
              "ioValue": 200
            },
            {
              "name": "primaryEdgeIndex",
              "ioValue": 0
