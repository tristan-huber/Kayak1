      "interpreterVersion": 1,
      "code": "\n/**\n * This code atom implements a simple linear layout funtion which repeats\n * shape count times in the positive X direction with offset space\n * between each. Works for either 2D or 3D shapes. Negative offset\n * and negative counts invert the direction.\n * \n * Notice that defaults are set for both count and offset.\n */\n\nconst pointsAndSpline = (points: [number, number, number][]) => {\n  console.log('bah')\n  const result = [];\n  result.push(\n    replicad.makeBSplineApproximation(points, {\n      degMax: 3,\n      degMin: 1,\n      tolerance: 0.01,\n    })\n  );\n\n  const q = replicad.makeSphere(0.5);\n  for (const p of points) {\n    console.log(p);\n    result.push(q.clone().translate(p[0], p[1], p[2]));\n  }\n  return result;\n};\n\nfunction pointsWithCamberedStart(\n  points: [number, number][],\n  stations: number[],\n  frontCamber: number,\n  backCamber: number\n): [number, number, number][] {\n  const result = [];\n  for (let i = 0; i < points.length; i++) {\n    let x = stations[i];\n    let z = points[i][1];\n    if (i == 0) {\n      x = Math.cos(frontCamber) * z; // instead of 0\n      z = Math.sin(frontCamber) * z;\n    }\n    if (i == points.length - 1) {\n      x = x - Math.cos(backCamber) * z;\n      z = Math.sin(backCamber) * z;\n    }\n\n    result.push([x, points[i][0], z]);\n  }\n  //@ts-ignore\n  return result;\n};\n\nfunction run(frontCamberDeg: number, rearCamberDeg: number) {\n  const keel_line: [number, number][] = [\n    [0, 16 + 7 / 16],\n    [0, 18 + 7 / 8],\n    [0, 21 + 7 / 8],\n    [0, 21],\n    [0, 18 + 9 / 16],\n  ];\n\n  const stationDists = [23 + 1 / 8, 24, 24, 23 + 1 / 8];\n\n  const spoints = [0];\n  for (const offset of stationDists) {\n    spoints.push(spoints[spoints.length - 1] + offset);\n  }\n  const frontCamber = frontCamberDeg * Math.PI / 180\n  const rearCamber = rearCamberDeg * Math.PI / 180\n\n  const t = pointsWithCamberedStart(keel_line, spoints, frontCamber, rearCamber);\n  return t.map(p => replicad.makeVertex(p))\n\n\n\n  const blep = [\n    pointsAndSpline(pointsWithCamberedStart(keel_line, spoints, frontCamber, rearCamber)),\n    pointsAndSpline(pointsWithCamberedStart(chine, spoints, frontCamber, rearCamber)),\n    pointsAndSpline(pointsWithCamberedStart(sheer, spoints, frontCamber, rearCamber)),\n  ];\n\n  console.log(\"blep\")\n  console.log(blep)\n  console.log(blep.length)\n  const wires = []\n  for (const res of blep) {\n    //@ts-ignore\n    wires.push(replicad.assembleWire([res[0]]))\n  }\n  console.log(wires)\n  return replicad.loft(wires)\n}",
      "compiledCode": "\"use strict\";\n/**\n * This code atom implements a simple linear layout funtion which repeats\n * shape count times in the positive X direction with offset space\n * between each. Works for either 2D or 3D shapes. Negative offset\n * and negative counts invert the direction.\n *\n * Notice that defaults are set for both count and offset.\n */\nconst pointsAndSpline = (points) => {\n    console.log('bah');\n    const result = [];\n    result.push(replicad.makeBSplineApproximation(points, {\n        degMax: 3,\n        degMin: 1,\n        tolerance: 0.01,\n    }));\n    const q = replicad.makeSphere(0.5);\n    for (const p of points) {\n        console.log(p);\n        result.push(q.clone().translate(p[0], p[1], p[2]));\n    }\n    return result;\n};\nfunction pointsWithCamberedStart(points, stations, frontCamber, backCamber) {\n    const result = [];\n    for (let i = 0; i < points.length; i++) {\n        let x = stations[i];\n        let z = points[i][1];\n        if (i == 0) {\n            x = Math.cos(frontCamber) * z; // instead of 0\n            z = Math.sin(frontCamber) * z;\n        }\n        if (i == points.length - 1) {\n            x = x - Math.cos(backCamber) * z;\n            z = Math.sin(backCamber) * z;\n        }\n        result.push([x, points[i][0], z]);\n    }\n    //@ts-ignore\n    return result;\n}\n;\nfunction run(frontCamberDeg, rearCamberDeg) {\n    const keel_line = [\n        [0, 16 + 7 / 16],\n        [0, 18 + 7 / 8],\n        [0, 21 + 7 / 8],\n        [0, 21],\n        [0, 18 + 9 / 16],\n    ];\n    const stationDists = [23 + 1 / 8, 24, 24, 23 + 1 / 8];\n    const spoints = [0];\n    for (const offset of stationDists) {\n        spoints.push(spoints[spoints.length - 1] + offset);\n    }\n    const frontCamber = frontCamberDeg * Math.PI / 180;\n    const rearCamber = rearCamberDeg * Math.PI / 180;\n    const t = pointsWithCamberedStart(keel_line, spoints, frontCamber, rearCamber);\n    return t.map(p => replicad.makeVertex(p));\n    const blep = [\n        pointsAndSpline(pointsWithCamberedStart(keel_line, spoints, frontCamber, rearCamber)),\n        pointsAndSpline(pointsWithCamberedStart(chine, spoints, frontCamber, rearCamber)),\n        pointsAndSpline(pointsWithCamberedStart(sheer, spoints, frontCamber, rearCamber)),\n    ];\n    console.log(\"blep\");\n    console.log(blep);\n    console.log(blep.length);\n    const wires = [];\n    for (const res of blep) {\n        //@ts-ignore\n        wires.push(replicad.assembleWire([res[0]]));\n    }\n    console.log(wires);\n    return replicad.loft(wires);\n}\n"
    },
